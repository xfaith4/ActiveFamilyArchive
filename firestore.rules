rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(email) {
      return get(/databases/$(database)/documents/authorized_users/$(email));
    }

    function isConfiguredAdminEmail() {
      return isSignedIn() &&
        request.auth.token.email == 'ben.fuhr@gmail.com';
    }

    function isAuthorizedUser() {
      return isConfiguredAdminEmail() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email))
      );
    }

    function isAdmin() {
      return isConfiguredAdminEmail() || (
        isAuthorizedUser() &&
        userDoc(request.auth.token.email).data.role == 'admin'
      );
    }

    function isModerator() {
      return isAuthorizedUser() && (
        isAdmin() ||
        userDoc(request.auth.token.email).data.role == 'moderator'
      );
    }

    function isContributor() {
      return isAuthorizedUser() && (
        isAdmin() ||
        userDoc(request.auth.token.email).data.role == 'moderator' ||
        userDoc(request.auth.token.email).data.role == 'contributor' ||
        userDoc(request.auth.token.email).data.role == 'user'
      );
    }

    function appMode() {
      return exists(/databases/$(database)/documents/app_config/governance)
        ? get(/databases/$(database)/documents/app_config/governance).data.mode
        : 'normal';
    }

    function isNormalMode() {
      return appMode() == 'normal';
    }

    function canCreateCollaboration() {
      return isContributor() && isNormalMode();
    }

    function canModerateCollaboration() {
      return isModerator();
    }

    function validAuthorizedUserRole() {
      return request.resource.data.role in ['viewer', 'contributor', 'moderator', 'admin', 'user'];
    }

    // Authorized users collection
    // Users can read their own authorization status
    // Existing admins can manage all docs.
    // The configured admin email may self-bootstrap exactly once on a fresh project.
    match /authorized_users/{email} {
      // Users can read their own doc; admins can read all docs (needed for Users tab)
      allow read: if isSignedIn() && (
        request.auth.token.email == email ||
        isAdmin()
      );
      allow create: if isSignedIn() && validAuthorizedUserRole() && (
        (
          request.auth.token.email == email &&
          email == 'ben.fuhr@gmail.com' &&
          !exists(/databases/$(database)/documents/authorized_users/$(email)) &&
          request.resource.data.email == email &&
          request.resource.data.role == 'admin'
        ) ||
        isAdmin()
      );
      allow update: if isAdmin() && validAuthorizedUserRole();
      allow delete: if isAdmin();
    }

    // Feedback collection
    // Any authorized (authenticated) user can submit feedback
    // Contributors can read their own submissions; only admins can review/update
    match /feedback/{feedbackId} {
      allow create: if canCreateCollaboration();
      allow read: if isAuthorizedUser() && (
        canModerateCollaboration() ||
        resource.data.submittedBy == request.auth.token.email
      );
      allow update: if canModerateCollaboration();
    }

    // Manual media links
    // All authorized users can read (so manually-linked photos appear on profiles for everyone)
    // Only admins can create, update, or delete links
    match /media_links/{linkId} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }

    // Submissions collection (factual corrections and photo contributions)
    // Any authorized user can submit; contributors can read their own items.
    // Only admins can approve/reject.
    match /submissions/{submissionId} {
      allow create: if canCreateCollaboration();
      allow read: if isAuthorizedUser() && (
        canModerateCollaboration() ||
        resource.data.submittedBy == request.auth.token.email
      );
      allow update: if canModerateCollaboration();
    }

    // Immediate profile overrides are readable to all authorized users so the
    // live profile reflects the most recent approved-in-scope edit.
    // Writes are restricted to the backend callable function via Admin SDK.
    match /person_profile_overrides/{personId} {
      allow read: if isAuthorizedUser();
      allow write: if false;
    }

    // Immutable audit log for in-app profile edits.
    match /person_change_log/{changeId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Admin notifications generated by backend profile-edit saves.
    match /admin_notifications/{notificationId} {
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow create, delete: if false;
    }

    // Review-outcome notifications for contributors.
    // Written only by backend automation; readable by the recipient and admins.
    match /user_notifications/{notificationId} {
      allow read: if isAuthorizedUser() && (
        isAdmin() ||
        resource.data.recipientEmail == request.auth.token.email
      );
      allow update: if isAuthorizedUser() && (
        isAdmin() ||
        resource.data.recipientEmail == request.auth.token.email
      ) && request.resource.data.recipientEmail == resource.data.recipientEmail
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'readAt', 'readBy'])
        && (
          isAdmin() ||
          request.resource.data.readBy == request.auth.token.email
        );
      allow create, delete: if false;
    }

    // Admin-set default tree layout — any authorized user can read; only admin can write.
    // Must be matched before the {email} wildcard rule.
    match /tree_layouts/_default {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }

    // Per-user tree layout positions.
    // Each user can read/write their own doc; admins can inspect/write/delete any doc
    // to manage shared default rollout and preserve selected custom layouts.
    match /tree_layouts/{email} {
      allow read, write: if isAdmin() || (
        isSignedIn() &&
        request.auth.token.email == email &&
        isAuthorizedUser() &&
        isNormalMode()
      );
    }

    // Photo uploads — user-contributed photos pending admin review.
    // Any authorized user can upload (create) and read approved or their own uploads.
    // Admin can read all and update status (approve/reject).
    match /photo_uploads/{uploadId} {
      allow create: if canCreateCollaboration();
      allow read: if isAuthorizedUser() && (
        canModerateCollaboration() ||
        resource.data.status == 'approved' ||
        resource.data.uploaderEmail == request.auth.token.email
      );
      allow update, delete: if canModerateCollaboration();
    }

    // Evidence uploads — user-contributed source documents (birth/marriage/death
    // certificates, obituaries, census scans, etc.) pending admin review.
    // Any authorized user can upload (create) and read approved or their own uploads.
    // Admin can read all and update status (approve/reject).
    match /evidence_uploads/{uploadId} {
      allow create: if canCreateCollaboration() &&
        request.resource.data.contributorEmail == request.auth.token.email &&
        request.resource.data.status == 'pending' &&
        request.resource.data.personId is string &&
        request.resource.data.personName is string &&
        request.resource.data.storagePath is string &&
        request.resource.data.storagePath.matches('evidence/.*') &&
        request.resource.data.downloadURL is string &&
        request.resource.data.mimeType is string &&
        (
          request.resource.data.mimeType.matches('image/.*') ||
          request.resource.data.mimeType == 'application/pdf'
        ) &&
        request.resource.data.fileSize is int &&
        request.resource.data.fileSize <= 15 * 1024 * 1024;
      allow read: if isAuthorizedUser() && (
        canModerateCollaboration() ||
        resource.data.status == 'approved' ||
        resource.data.contributorEmail == request.auth.token.email
      );
      allow update, delete: if canModerateCollaboration();
    }

    // AI-generated photo notes.
    // Any authorized user can read published notes.
    // Only admin can read drafts and write (create/update).
    match /photo_descriptions/{docId} {
      allow read: if isAuthorizedUser() && (
        isAdmin() ||
        resource.data.status == 'published'
      );
      allow write: if isAdmin();
    }

    // User-submitted photo notes (community notes).
    // Any authorized user can read and create.
    // Authors can delete their own notes; admins can delete any.
    match /photo_notes/{noteId} {
      allow read: if isAuthorizedUser();
      allow create: if canCreateCollaboration() &&
        request.resource.data.authorEmail == request.auth.token.email;
      allow delete: if isAuthorizedUser() && (
        isAdmin() ||
        resource.data.authorEmail == request.auth.token.email
      );
    }

    // User-submitted person tags on photos.
    // Any authorized user can read and create.
    // Taggers can remove their own tags; admins can remove any.
    match /photo_person_tags/{tagId} {
      allow read: if isAuthorizedUser();
      allow create: if canCreateCollaboration() &&
        request.resource.data.taggedBy == request.auth.token.email;
      allow delete: if isAuthorizedUser() && (
        isAdmin() ||
        resource.data.taggedBy == request.auth.token.email
      );
    }

    // App-level configuration (invitation template, etc.)
    // Readable by all authorized users; writable only by admin.
    match /app_config/governance {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin() &&
        request.resource.data.mode in ['normal', 'historical_read_only'] &&
        request.resource.data.policyVersion is string &&
        request.resource.data.updatedBy == request.auth.token.email;
    }

    match /app_config/{configId} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin() && configId != 'governance';
    }

    // Family Message Board — top-level posts.
    // Any contributor can create posts during normal mode; contributors cannot
    // post while the archive is in historical_read_only mode. Existing posts
    // remain readable to all authorized users in any mode. Authors can edit or
    // delete their own posts; admins can delete any post.
    //
    // Field contract on create:
    //   Required: authorEmail (== auth email), authorName (1..80 chars),
    //             body (1..4000 chars), createdAt (== request.time)
    //   Optional: imageUrl (https:// only), imageStoragePath (must live under
    //             board/{postId}/), replyCount (must be 0), editedAt (must be null)
    // These pins prevent author impersonation, feed backdating, spoofed reply
    // counts, cross-post image theft, and arbitrary image source URLs.
    match /board_posts/{postId} {
      allow read: if isAuthorizedUser();
      allow create: if canCreateCollaboration()
        && request.resource.data.keys().hasAll(['authorEmail', 'authorName', 'body', 'createdAt'])
        && request.resource.data.keys().hasOnly([
             'authorEmail', 'authorName', 'body', 'createdAt',
             'imageUrl', 'imageStoragePath', 'replyCount', 'editedAt'
           ])
        && request.resource.data.authorEmail == request.auth.token.email
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 4000
        && request.resource.data.createdAt == request.time
        && (!('imageUrl' in request.resource.data)
            || (request.resource.data.imageUrl is string
                && request.resource.data.imageUrl.matches('^https://.*')))
        && (!('imageStoragePath' in request.resource.data)
            || (request.resource.data.imageStoragePath is string
                && request.resource.data.imageStoragePath.matches('^board/' + postId + '/.*')))
        && (!('replyCount' in request.resource.data)
            || request.resource.data.replyCount == 0)
        && (!('editedAt' in request.resource.data)
            || request.resource.data.editedAt == null);
      allow update: if isAuthorizedUser() && isNormalMode()
        && resource.data.authorEmail == request.auth.token.email
        && request.resource.data.authorEmail == resource.data.authorEmail
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['body', 'editedAt'])
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 4000
        && request.resource.data.editedAt == request.time;
      allow delete: if isAdmin()
        || (resource.data.authorEmail == request.auth.token.email && isNormalMode());
    }

    // Family Message Board — replies to a specific post.
    // Same gating as posts. parentPostId must reference an existing post so
    // orphaned replies cannot be created.
    match /board_replies/{replyId} {
      allow read: if isAuthorizedUser();
      allow create: if canCreateCollaboration()
        && request.resource.data.keys().hasAll(['authorEmail', 'authorName', 'body', 'createdAt', 'parentPostId'])
        && request.resource.data.keys().hasOnly([
             'authorEmail', 'authorName', 'body', 'createdAt',
             'parentPostId', 'editedAt'
           ])
        && request.resource.data.authorEmail == request.auth.token.email
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.createdAt == request.time
        && request.resource.data.parentPostId is string
        && exists(/databases/$(database)/documents/board_posts/$(request.resource.data.parentPostId))
        && (!('editedAt' in request.resource.data)
            || request.resource.data.editedAt == null);
      allow update: if isAuthorizedUser() && isNormalMode()
        && resource.data.authorEmail == request.auth.token.email
        && request.resource.data.authorEmail == resource.data.authorEmail
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['body', 'editedAt'])
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.editedAt == request.time;
      allow delete: if isAdmin()
        || (resource.data.authorEmail == request.auth.token.email && isNormalMode());
    }

    // Content flags — lightweight user reports on posts or replies.
    // One flag per user per target is enforced here by requiring the doc id
    // to be "{flaggerEmail}_{targetType}_{targetId}". Flags are write-once
    // for the reporter and resolvable only by moderators.
    match /content_flags/{flagId} {
      allow read: if isAuthorizedUser() && (
        canModerateCollaboration() ||
        resource.data.flaggerEmail == request.auth.token.email
      );
      allow create: if canCreateCollaboration()
        && request.resource.data.flaggerEmail == request.auth.token.email
        && request.resource.data.targetType in ['post', 'reply']
        && request.resource.data.targetId is string
        && request.resource.data.status == 'open'
        && flagId == request.auth.token.email + '_'
                     + request.resource.data.targetType + '_'
                     + request.resource.data.targetId;
      allow update: if canModerateCollaboration()
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['status', 'resolvedBy', 'resolvedAt'])
        && request.resource.data.status in ['open', 'resolved'];
      allow delete: if false;
    }

    // Immutable audit log for governance mode and role-assignment changes.
    match /governance_audit/{auditId} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.actorEmail == request.auth.token.email &&
        request.resource.data.action in ['mode_change', 'role_change'];
      allow update, delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
