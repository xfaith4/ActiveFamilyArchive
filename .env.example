# Firebase Configuration Example
# Copy this file and update with your actual Firebase project values
# DO NOT commit this file with real values to a public repository

# Get these values from Firebase Console > Project Settings > Your apps > Web app

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Admin email - this user will have admin privileges
VITE_ADMIN_EMAIL=your-admin-email@example.com

# Local development password - enables the "Login Locally" button on localhost.
# Set this to a strong, unique value. If unset, local login is disabled entirely.
# This value is only used on localhost and is never sent to any server.
VITE_LOCAL_DEV_PASSWORD=your_local_dev_password_here

# ── Cloud Functions configuration ──────────────────────────────────────────────
# The generatePhotoNote Cloud Function uses the Google Gemini API to generate
# descriptive notes for family photos. Obtain an API key at:
#   https://aistudio.google.com/app/apikey
# Set this on the deployed function with:
#   firebase functions:config:set gemini.api_key="YOUR_GEMINI_API_KEY"
# Or store it as a Secret Manager secret named GEMINI_API_KEY and reference it
# in the function environment.
